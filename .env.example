# ==========================================
# Transcripthub - Unified Environment Config
# ==========================================
# Copy this file to `.env.local` (for Next.js) and/or `.env` (for Python service).
# Fill the values before running in production.

# ------------------------------------------------------------------------------
# 1) Auth (Google OAuth + user backend)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_AUTH_BASE_URL=https://api.transcripthub.net
AUTH_BASE_URL=https://api.transcripthub.net
AUTH_CREDIT_CONSUME_PATH=/prod-api/g/credits/consume

NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=https://api.transcripthub.net/prod-api/g/callback

# Guest direct-link daily cap (across TikTok/Instagram/Facebook)
GUEST_DAILY_LIMIT=2

# Direct-link safety and throttling
DIRECT_LINK_RETRY_ATTEMPTS=3
DIRECT_LINK_RETRY_BASE_DELAY_MS=500
DIRECT_LINK_IP_RATE_LIMIT_ENABLED=true
DIRECT_LINK_IP_WINDOW_SECONDS=60
DIRECT_LINK_IP_MAX_REQUESTS_GUEST=120
DIRECT_LINK_IP_MAX_REQUESTS_USER=300

# Optional app canonical base URL used in callback URL construction
NEXT_PUBLIC_APP_BASE_URL=https://transcripthub.net

# ------------------------------------------------------------------------------
# 2) Transcript backend target (Next.js API proxy -> transcript service)
# ------------------------------------------------------------------------------
TRANSCRIPT_BACKEND_URL=https://ytdlp.vistaflyer.com
NEXT_PUBLIC_TRANSCRIPT_BACKEND_URL=https://ytdlp.vistaflyer.com

# ------------------------------------------------------------------------------
# 3) Billing backend target (Next.js BFF -> external payment backend)
# ------------------------------------------------------------------------------
BILLING_BASE_URL=https://api.your-billing-domain.com
NEXT_PUBLIC_BILLING_BASE_URL=https://api.your-billing-domain.com

# Feature flag
NEXT_PUBLIC_PAYMENTS_ENABLED=true

# Client-side checkout SDK keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_xxx
NEXT_PUBLIC_PAYPAL_CLIENT_ID=paypal_client_id_xxx

# ------------------------------------------------------------------------------
# 4) Billing plan code mapping (frontend plan -> backend plan)
# ------------------------------------------------------------------------------
BILLING_PLAN_PRO_MONTHLY=pro_monthly
BILLING_PLAN_PRO_YEARLY=pro_yearly
BILLING_PLAN_PAYG_150=payg_150

# ------------------------------------------------------------------------------
# 5) Billing backend path overrides (optional)
# ------------------------------------------------------------------------------
BILLING_STRIPE_CREATE_PATH=/prod-api/stripe/getPayUrl
BILLING_STRIPE_VERIFY_PATH=/prod-api/stripe/check-order-status

BILLING_PAYPAL_CREATE_ORDER_PATH=/prod-api/paypal/smart/create-order
BILLING_PAYPAL_CREATE_SUBSCRIPTION_PATH=/prod-api/paypal/smart/create-subscription
BILLING_PAYPAL_CAPTURE_PATH=/prod-api/paypal/smart/capture-order
BILLING_PAYPAL_VERIFY_SUBSCRIPTION_PATH=/prod-api/paypal/smart/verify-subscription

BILLING_PORTAL_PATH=/prod-api/pay/portal
BILLING_ORDERS_PATH=/prod-api/pay/orders

# ------------------------------------------------------------------------------
# 6) ASR provider (HuggingFace) for Python transcript services
# ------------------------------------------------------------------------------
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_ASR_MODEL=openai/whisper-large-v3
HF_ASR_URL=https://router.huggingface.co/hf-inference/models/openai/whisper-large-v3
HF_ASR_LEGACY_URL=https://api-inference.huggingface.co/models/openai/whisper-large-v3

# ------------------------------------------------------------------------------
# 7) TikTok transcript service knobs
# ------------------------------------------------------------------------------
TIKTOK_ASR_TIMEOUT_SECONDS=180
TIKTOK_ASR_MAX_BYTES=25165824
TIKTOK_ASR_RAW_MAX_BYTES=134217728
TIKTOK_ASR_FFMPEG_TIMEOUT_SECONDS=180
TIKTOK_IMPERSONATE_TARGET=chrome
TIKTOK_APP_INFO=musical_ly/35.1.3/2023501030/1233
TIKTOK_DEVICE_ID=
TIKTOK_API_HOSTNAME=
TIKTOK_ENABLE_YTDLP_CLI_FALLBACK=1
TIKTOK_YTDLP_CLI_TIMEOUT_SECONDS=120
TIKTOK_INFO_PROXY_URL=
TIKTOK_ENABLE_BUILTIN_PROXY=1

# ------------------------------------------------------------------------------
# 8) Instagram transcript service knobs
# ------------------------------------------------------------------------------
INSTAGRAM_ASR_TIMEOUT_SECONDS=180
INSTAGRAM_ASR_MAX_BYTES=25165824
INSTAGRAM_ASR_RAW_MAX_BYTES=134217728
INSTAGRAM_ASR_FFMPEG_TIMEOUT_SECONDS=180
INSTAGRAM_IMPERSONATE_TARGET=chrome
INSTAGRAM_APP_INFO=
INSTAGRAM_ENABLE_YTDLP_CLI_FALLBACK=1
INSTAGRAM_YTDLP_CLI_TIMEOUT_SECONDS=120
INSTAGRAM_INFO_PROXY_URL=
INSTAGRAM_ENABLE_BUILTIN_PROXY=1

# ------------------------------------------------------------------------------
# 9) Facebook transcript service knobs
# ------------------------------------------------------------------------------
FACEBOOK_ASR_TIMEOUT_SECONDS=180
FACEBOOK_ASR_MAX_BYTES=25165824
FACEBOOK_ASR_RAW_MAX_BYTES=134217728
FACEBOOK_ASR_FFMPEG_TIMEOUT_SECONDS=180
FACEBOOK_IMPERSONATE_TARGET=chrome
FACEBOOK_APP_INFO=
FACEBOOK_ENABLE_YTDLP_CLI_FALLBACK=1
FACEBOOK_YTDLP_CLI_TIMEOUT_SECONDS=120
FACEBOOK_INFO_PROXY_URL=
FACEBOOK_ENABLE_BUILTIN_PROXY=1

# ------------------------------------------------------------------------------
# 10) ARK AI stream summary service (app.py)
# ------------------------------------------------------------------------------
ARK_API_KEY=
ARK_MODEL=glm-4-7-251222
ARK_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
